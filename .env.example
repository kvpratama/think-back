# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=
SUPABASE_KEY=

# OpenAI Configuration
OPENAI_API_KEY=

# Google Gemini Configuration
GEMINI_API_KEY=

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# LLM Configuration (optional - leave blank to use defaults)
LLM_MODEL=
LLM_PROVIDER=
LLM_PROVIDER_BASE_URL=

# Embedding Configuration (optional - leave blank to use defaults)
EMBEDDING_MODEL=

# LLM for evaluation (optional - leave blank to use defaults)
EVAL_LLM_MODEL=
EVAL_LLM_PROVIDER=
EVAL_LLM_PROVIDER_BASE_URL=

# Langsmith Configuration for tracing (optional)
LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
