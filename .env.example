# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=
SUPABASE_KEY=

# OpenAI Configuration
OPENAI_API_KEY=

# Google Gemini Configuration
GEMINI_API_KEY=

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
