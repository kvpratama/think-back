# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=
SUPABASE_KEY=

# Direct Postgres connection string for LangGraph checkpointer (persistent conversation state)
# Get this from Supabase Dashboard → Settings → Database → Connection string (URI)
# Example: postgresql://postgres.<ref>:<password>@<host>:5432/postgres
DATABASE_URL=

# OpenAI Configuration
OPENAI_API_KEY=

# Google Gemini Configuration
GEMINI_API_KEY=

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# LLM Configuration (optional - leave blank to use defaults)
LLM_MODEL=
LLM_PROVIDER=
LLM_PROVIDER_BASE_URL=

# Embedding Configuration (optional - leave blank to use defaults)
EMBEDDING_MODEL=

# Search Configuration (optional - leave blank to use defaults)
SEARCH_TOP_K=

# LLM for evaluation (optional - leave blank to use defaults)
EVAL_LLM_MODEL=
EVAL_LLM_PROVIDER=
EVAL_LLM_PROVIDER_BASE_URL=
EVAL_LLM_API_KEY=

# JSON array of judge configs (minimum 2 entries). Each object:
#   model            – model name (e.g. "gpt-4o", "sonnet-4")
#   provider         – LangChain provider id (e.g. "openai", "anthropic")
#   api_key_field    – name of a SecretStr field on Settings (e.g. "openai_api_key"), NOT the raw key
#   base_url         – optional custom endpoint (leave "" for default)
#
# Example:
# EVAL_JURY_JUDGES='[{"model":"gpt-4o","provider":"openai","api_key_field":"openai_api_key","base_url":""},{"model":"sonnet-4","provider":"anthropic","api_key_field":"anth_api_key","base_url":""}]'
EVAL_JURY_JUDGES=

# Webhook Configuration (optional - leave blank for polling mode in local dev)
# Set WEBHOOK_URL to your public HTTPS URL to enable webhook mode (e.g., Railway)
# Do not include a trailing slash (e.g., https://my-app.up.railway.app)
WEBHOOK_URL=
# Secret token for Telegram to verify webhook requests
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=
# Port for the webhook server (Railway sets this automatically)
PORT=8000

# Langsmith Configuration for tracing (optional)
LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
